# Copy to `.env` and adjust. These configure the Vite dev/preview server
# (read in vite.config.ts via loadEnv). All are optional — sensible localhost
# defaults apply when unset. `.env` is git-ignored; this template is tracked.

# Bind publicly on 0.0.0.0:8000 (an edge / reverse proxy terminates TLS + auth).
# Set to 1 to enable; unset → bind 127.0.0.1:5173 for local dev.
MSP_TREES_PUBLIC=

# Load the self-signed cert from app/.certs/ for a local HTTPS dev server.
# Only needed when bypassing the edge proxy. Set to 1 to enable.
MSP_TREES_TLS=

# Comma-separated public/proxied hostname(s) the server should accept, so a
# reverse proxy's forwarded Host header passes Vite's DNS-rebinding check.
# Example: trees.example.com,www.trees.example.com
MSP_TREES_ALLOWED_HOST=
