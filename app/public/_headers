# Cloudflare Pages response headers. Vite copies this file verbatim from public/
# into the build output (dist/_headers). A URL pattern on one line, its headers
# indented beneath; one `*` splat per pattern, 100 rules max.
#
# NOTE: `_headers` does NOT apply to responses generated by Pages Functions, even
# when the request path matches a rule here. /data/trees.geojson is streamed from
# R2 by functions/data/trees.geojson.js, which sets its own Cache-Control — the
# /data/* rule below never reaches it. Retune the 51 MB point set there, not here.
#
# HTML is deliberately left on the Pages default (max-age=0, must-revalidate) so
# that a new deploy's hashed asset names are picked up on the very next visit.

# Vite fingerprints everything under assets/ with a content hash, so changed
# content always means a changed URL. Safe to cache for a year; `immutable` also
# suppresses the revalidation request browsers otherwise send on a reload.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Pre-aggregated pipeline outputs: hexbin.geojson, trees.sample.geojson,
# species-counts.json. These are NOT content-hashed — a re-extract rewrites them
# at the same URL — so they cannot be `immutable`. Same policy the trees.geojson
# Function already chose: a day at the browser, a week at the edge.
#
# hexbin.geojson is the file that paints the map (1.05 MB, 118 KB brotli). On the
# Pages default it revalidated on every single visit.
/data/*
  Cache-Control: public, max-age=86400, s-maxage=604800
