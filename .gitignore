# Raw source data — large and re-downloadable from the original providers
data/raw/

# Generated outputs (maps, exports, reports) — derived, not source-controlled.
# Ignore the contents but keep the empty directory tracked via its .gitkeep.
outputs/*
!outputs/.gitkeep

# QGIS lock and backup files
*.qgz~
*.qgs~
*.lck

# macOS / Windows OS metadata files
.DS_Store
Thumbs.db

# Machine-local Claude Code settings — per-developer, not shared
.claude/settings.local.json

# Python artifacts
__pycache__/
.venv/
*.pyc

# Pipeline build artifacts (GeoJSON, PMTiles) — re-derivable from data/raw/.
# Exception: the three small pre-aggregated files below are committed because the
# Pages deploy must ship them and CI builds from a clean checkout with no raw
# data. They're small (~4.2 MB total) and stable; committing them keeps every
# build reproducible with no extra fetch step. The 51 MB trees.geojson stays out
# and lives in R2 (uploaded manually with `deploy:cf r2` on a data re-extract).
data/processed/*
!data/processed/.gitkeep
!data/processed/hexbin.geojson
!data/processed/species-counts.json
!data/processed/trees.sample.geojson

# Node / Bun deps and build output — re-derivable from package.json + bun.lockb
node_modules/
app/dist/
app/.vite/

# Local environment secrets — must never be committed (per global rules)
.env
.env.local
.env.*.local

# TLS material for the local HTTPS dev server — host-specific, regenerable
app/.certs/

# Vite / Bun caches
.vite/
.bun/

# Local wrangler cache/state, created by `wrangler pages dev` when verifying the
# built output (e.g. the _headers rules) against a local Pages runtime
.wrangler/

# Local runtime artifacts — dev-server logs and verification screenshots (ignore contents, not the dir itself)
outputs/*
# Keep the directory's README explaining its purpose, despite ignoring its contents
!outputs/README.md
